# OpenAI-compatible LLM provider — same shape as the cct/server config
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Server
PORT=8080

# CORS — comma-separated list of allowed origins, or "*" for any
# When the HTML demo is opened as a file:// URL the Origin is "null"; "*" handles that.
CORS_ORIGINS=*
